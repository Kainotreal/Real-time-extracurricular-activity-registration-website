@model IEnumerable<QuanLyHoatDongNgoaiKhoa.Models.HoatDong>

@{
    ViewData["Title"] = "Quản lý hoạt động ngoại khóa";
}

<!-- Thông báo thành công -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Thông báo lỗi -->
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Import modern CSS -->
<link rel="stylesheet" href="~/css/modern-activity.css" />

<!-- Import modern JavaScript -->
<script src="~/js/modern-activity.js"></script>

<style>
    /* Import Google Fonts */
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
    @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

    /* CSS Variables */
    :root {
        --primary-color: #6366f1;
        --primary-dark: #4f46e5;
        --secondary-color: #f59e0b;
        --success-color: #10b981;
        --danger-color: #ef4444;
        --warning-color: #f59e0b;
        --info-color: #3b82f6;
        --dark-color: #1f2937;
        --light-color: #f8fafc;
        --gray-color: #6b7280;
        --border-color: #e5e7eb;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
        --border-radius: 12px;
        --border-radius-lg: 16px;
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Global Styles */
    body {
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
    }

    .container-fluid {
        padding: 2rem;
    }

    /* Header Section */
    .page-header {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-radius: var(--border-radius-lg);
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: var(--shadow-lg);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .page-title {
        font-family: 'Poppins', sans-serif;
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--dark-color);
        margin-bottom: 0.5rem;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .page-subtitle {
        font-size: 1.1rem;
        color: var(--gray-color);
        font-weight: 400;
    }

    /* Stats Cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin-top: 2rem;
    }

    .stat-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: var(--border-radius);
        padding: 1.5rem;
        text-align: center;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(255, 255, 255, 0.2);
        transition: var(--transition);
        position: relative;
        overflow: hidden;
    }

    .stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-xl);
    }

    .stat-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        box-shadow: var(--shadow-md);
    }

    .stat-icon i {
        font-size: 1.5rem;
        color: white;
    }

    .stat-number {
        font-family: 'Poppins', sans-serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--dark-color);
        display: block;
        margin-bottom: 0.5rem;
    }

    .stat-label {
        font-size: 0.9rem;
        color: var(--gray-color);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Activity Cards */
    .activities-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 1.5rem;
    }

    .activity-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-radius: var(--border-radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-lg);
        border: 1px solid rgba(255, 255, 255, 0.2);
        transition: var(--transition);
        position: relative;
    }

    .activity-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-xl);
    }

    .card-header {
        background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
        padding: 1.5rem;
        color: white;
        position: relative;
    }

    .card-header::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="50" cy="50" r="1" fill="white" opacity="0.1"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>');
        opacity: 0.3;
    }

    .activity-status {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .activity-id {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: rgba(255, 255, 255, 0.9);
        color: var(--dark-color);
        padding: 0.25rem 0.75rem;
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: 600;
        backdrop-filter: blur(10px);
    }

    .card-body {
        padding: 1.5rem;
    }

    .activity-title {
        font-family: 'Poppins', sans-serif;
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--dark-color);
        margin-bottom: 0.75rem;
        line-height: 1.4;
    }

    .activity-description {
        color: var(--gray-color);
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
    }

    .activity-time {
        margin-bottom: 1.5rem;
    }

    .time-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
        padding: 1rem;
        background: rgba(99, 102, 241, 0.05);
        border-radius: var(--border-radius);
        border: 1px solid rgba(99, 102, 241, 0.1);
    }

    .time-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .time-content {
        flex: 1;
    }

    .time-label {
        font-size: 0.8rem;
        color: var(--gray-color);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.25rem;
    }

    .time-value {
        font-size: 0.95rem;
        color: var(--dark-color);
        font-weight: 600;
    }

    .activity-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.75rem;
        background: rgba(99, 102, 241, 0.05);
        border-radius: 20px;
        font-size: 0.85rem;
        color: var(--gray-color);
        border: 1px solid rgba(99, 102, 241, 0.1);
    }

    .meta-item i {
        color: var(--primary-color);
        font-size: 0.9rem;
    }

    .registration-status {
        margin-bottom: 1.5rem;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        border: 1px solid;
    }

    .status-pending {
        background: linear-gradient(135deg, var(--warning-color), #f97316);
        color: white;
        border-color: var(--warning-color);
    }

    .status-confirmed {
        background: linear-gradient(135deg, var(--success-color), #059669);
        color: white;
        border-color: var(--success-color);
    }

    .status-rejected {
        background: linear-gradient(135deg, var(--danger-color), #dc2626);
        color: white;
        border-color: var(--danger-color);
    }

    .status-not-registered {
        background: linear-gradient(135deg, var(--gray-color), #4b5563);
        color: white;
        border-color: var(--gray-color);
    }

    .card-footer {
        padding: 1.5rem;
        background: rgba(248, 250, 252, 0.8);
        border-top: 1px solid var(--border-color);
    }

    .action-buttons {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-action {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        transition: var(--transition);
        border: none;
        position: relative;
        overflow: hidden;
    }

    .btn-action::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
        transition: left 0.5s;
    }

    .btn-action:hover::before {
        left: 100%;
    }

    .btn-action:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
    }

    .btn-info {
        background: linear-gradient(135deg, var(--info-color), #2563eb);
        color: white;
    }

    .btn-warning {
        background: linear-gradient(135deg, var(--warning-color), #f97316);
        color: white;
    }

    .btn-danger {
        background: linear-gradient(135deg, var(--danger-color), #dc2626);
        color: white;
    }

    .btn-success {
        background: linear-gradient(135deg, var(--success-color), #059669);
        color: white;
    }

    .registration-disabled {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--gray-color);
        color: white;
        cursor: not-allowed;
        opacity: 0.6;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-radius: var(--border-radius-lg);
        box-shadow: var(--shadow-lg);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .empty-icon {
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 2rem;
        color: white;
        font-size: 3rem;
        box-shadow: var(--shadow-lg);
    }

    .empty-state h3 {
        color: var(--dark-color);
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 1rem;
        font-family: 'Poppins', sans-serif;
    }

    .empty-state p {
        color: var(--gray-color);
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .container-fluid {
            padding: 1rem;
        }

        .page-title {
            font-size: 2rem;
        }

        .page-header {
            padding: 1.5rem;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }

        .activities-grid {
            grid-template-columns: 1fr;
        }

        .action-buttons {
            flex-wrap: wrap;
        }
    }

    @@media (max-width: 576px) {
        .page-title {
            font-size: 1.5rem;
        }

        .stat-card {
            padding: 1rem;
        }

        .activity-meta {
            flex-direction: column;
            gap: 0.5rem;
        }
    }

    /* Animation */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .activity-card {
        animation: fadeInUp 0.6s ease-out;
    }

    /* Glassmorphism Effects */
    .glass-effect {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    /* Custom Scrollbar */
    ::-webkit-scrollbar {
        width: 8px;
    }

    ::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb {
        background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
        border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb:hover {
        background: linear-gradient(135deg, var(--primary-dark), var(--primary-color));
    }
</style>

<div class="container-fluid">
    <!-- Header Section -->
    <div class="page-header">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h1 class="page-title">
                    <i class="fas fa-calendar-alt me-3"></i>Danh sách hoạt động ngoại khóa
                </h1>
                <p class="page-subtitle">Quản lý và theo dõi các hoạt động ngoại khóa</p>
            </div>
            <div>
                @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                {
                    <a asp-action="Create" class="btn btn-primary" style="background: linear-gradient(135deg, var(--primary-color), var(--primary-dark)); border: none; padding: 0.75rem 1.5rem; border-radius: var(--border-radius); font-weight: 600; transition: var(--transition);">
                        <i class="fas fa-plus me-2"></i>Tạo hoạt động mới
                    </a>
                }
            </div>
        </div>
        
        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <span class="stat-number">@Model.Count()</span>
                <span class="stat-label">Hoạt động</span>
            </div>
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-users"></i>
                </div>
                <span class="stat-number">@Model.Sum(h => h.DanhSachDangKy?.Count ?? 0)</span>
                <span class="stat-label">Đăng ký</span>
            </div>
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-clock"></i>
                </div>
                <span class="stat-number">@Model.Count(h => h.ThoiGianBatDau > DateTime.Now)</span>
                <span class="stat-label">Sắp diễn ra</span>
            </div>
        </div>
    </div>

    <!-- Activities Grid -->
    <div class="activities-grid">
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="activity-card" data-aos="fade-up" data-aos-delay="@(Model.ToList().IndexOf(item) * 100)">
                    <div class="card-header">
                        <div class="activity-status @GetStatusClass(item.TrangThaiHoatDong?.TenTrangThai)">
                            <i class="fas @GetStatusIcon(item.TrangThaiHoatDong?.TenTrangThai)"></i>
                            <span>@item.TrangThaiHoatDong?.TenTrangThai</span>
                        </div>
                        <div class="activity-id">
                            #@item.MaHoatDong
                        </div>
                    </div>
                    
                    <div class="card-body">
                        <h5 class="activity-title">@item.TieuDe</h5>
                        <p class="activity-description">@item.MoTa</p>
                        
                        <div class="activity-time">
                            <div class="time-item">
                                <div class="time-icon">
                                    <i class="fas fa-play-circle"></i>
                                </div>
                                <div class="time-content">
                                    <span class="time-label">Bắt đầu</span>
                                    <span class="time-value">@item.ThoiGianBatDau.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                            </div>
                            <div class="time-item">
                                <div class="time-icon">
                                    <i class="fas fa-stop-circle"></i>
                                </div>
                                <div class="time-content">
                                    <span class="time-label">Kết thúc</span>
                                    <span class="time-value">@item.ThoiGianKetThuc.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="activity-meta">
                            <div class="meta-item">
                                <i class="fas fa-user"></i>
                                <span>@(item.NguoiTao?.UserName ?? item.NguoiTaoId)</span>
                            </div>
                            <div class="meta-item">
                                <i class="fas fa-calendar"></i>
                                <span>@item.NgayTao.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="meta-item">
                                <i class="fas fa-users"></i>
                                <span>@(item.DanhSachDangKy?.Count ?? 0) người</span>
                            </div>
                            @if (User.IsInRole("Student"))
                            {
                                <div class="meta-item">
                                    <i class="fas fa-info-circle"></i>
                                    <span>Trạng thái: @item.MaTrangThai (@item.TrangThaiHoatDong?.TenTrangThai)</span>
                                </div>
                            }
                        </div>
                        
                        @if (User.IsInRole("Student"))
                        {
                            <div class="registration-status">
                                @{
                                    var studentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                                    var studentRegistration = item.DanhSachDangKy?.FirstOrDefault(dk => dk.UserId == studentUserId);
                                }
                                @if (studentRegistration != null)
                                {
                                    <span class="status-badge @GetRegistrationStatusClass(studentRegistration.TrangThaiDangKy?.TenTrangThaiDangKy)">
                                        <i class="fas fa-user-check"></i>
                                        @studentRegistration.TrangThaiDangKy?.TenTrangThaiDangKy
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-not-registered">
                                        <i class="fas fa-user-times"></i>
                                        Chưa đăng ký
                                    </span>
                                }
                            </div>
                        }
                    </div>
                    
                    <div class="card-footer">
                        <div class="action-buttons">
                            <a asp-action="Details" asp-route-id="@item.MaHoatDong" 
                               class="btn-action btn-info" title="Chi tiết">
                                <i class="fas fa-eye"></i>
                            </a>
                            
                            @{
                                var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                                var canEdit = User.IsInRole("Admin") || 
                                             (User.IsInRole("Teacher") && item.NguoiTaoId == currentUserId);
                                var isStudent = User.IsInRole("Student");
                                var isFutureActivity = item.ThoiGianBatDau > DateTime.Now;
                                var isConfirmedActivity = item.MaTrangThai == 2; // Đã xác nhận
                                var isPendingActivity = item.MaTrangThai == 1; // Chờ xác nhận
                                var userRegistration = item.DanhSachDangKy?.FirstOrDefault(dk => dk.UserId == currentUserId);
                                
                                // Bỏ nút đăng ký màu xanh - chỉ giữ lại các nút khác
                            }
                            
                            @if (isStudent && !isConfirmedActivity && isFutureActivity)
                            {
                                <div class="registration-disabled" title="Hoạt động chưa được xác nhận">
                                    <i class="fas fa-clock"></i>
                                </div>
                            }
                            
                            @if (isStudent && userRegistration != null && userRegistration.MaTrangThaiDangKy == 1)
                            {
                                <a href="/DangKyThamGia/Delete/@userRegistration.MaDangKy" 
                                   class="btn-action btn-danger" title="Hủy đăng ký"
                                   onclick="return confirm('Bạn có chắc chắn muốn hủy đăng ký?')">
                                    <i class="fas fa-user-minus"></i>
                                </a>
                            }
                            
                            @if (canEdit)
                            {
                                <a asp-action="Edit" asp-route-id="@item.MaHoatDong" 
                                   class="btn-action btn-warning" title="Sửa">
                                    <i class="fas fa-edit"></i>
                                </a>
                                
                                @if (item.DanhSachDangKy?.Any() == true)
                                {
                                    <button type="button" class="btn-action btn-info" title="Ẩn hoạt động"
                                            onclick="showHideConfirmation(@item.MaHoatDong, '@item.TieuDe')">
                                        <i class="fas fa-eye-slash"></i>
                                    </button>
                                }
                                else
                                {
                                    <a asp-action="Delete" asp-route-id="@item.MaHoatDong" 
                                       class="btn-action btn-danger" title="Xóa"
                                       onclick="return confirm('Bạn có chắc chắn muốn xóa hoạt động này?')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-calendar-times"></i>
                </div>
                <h3>Chưa có hoạt động nào</h3>
                <p>Hãy tạo hoạt động đầu tiên để bắt đầu!</p>
                @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                {
                    <a asp-action="Create" class="btn btn-primary" style="background: linear-gradient(135deg, var(--primary-color), var(--primary-dark)); border: none; padding: 0.75rem 1.5rem; border-radius: var(--border-radius); font-weight: 600; transition: var(--transition);">
                        <i class="fas fa-plus me-2"></i>Tạo hoạt động mới
                    </a>
                }
            </div>
        }
    </div>
</div>

@functions {
    private string GetStatusClass(string? status)
    {
        return status switch
        {
            "Chuẩn bị" => "status-preparing",
            "Đang diễn ra" => "status-ongoing",
            "Đã kết thúc" => "status-completed",
            "Đã hủy" => "status-cancelled",
            _ => "status-default"
        };
    }
    
    private string GetStatusIcon(string? status)
    {
        return status switch
        {
            "Chuẩn bị" => "fa-clock",
            "Đang diễn ra" => "fa-play-circle",
            "Đã kết thúc" => "fa-check-circle",
            "Đã hủy" => "fa-times-circle",
            _ => "fa-info-circle"
        };
    }
    
    private string GetRegistrationStatusClass(string? status)
    {
        return status switch
        {
            "Chờ xác nhận" => "status-pending",
            "Đã xác nhận" => "status-confirmed",
            "Đã từ chối" => "status-rejected",
            _ => "status-default"
        };
    }
} 
