<!-- FullCalendar Scripts -->
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/locales/vi.global.min.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        initializeRecentActivitiesCalendar();
    });

    function initializeRecentActivitiesCalendar() {
        const calendarEl = document.getElementById('recentActivitiesCalendar');
        if (!calendarEl) return;

        const calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            locale: 'vi',
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek'
            },
            buttonText: {
                today: 'Hôm nay',
                month: 'Tháng',
                week: 'Tuần'
            },
            events: function(fetchInfo, successCallback, failureCallback) {
                loadRecentActivitiesForCalendar(successCallback);
            },
            eventClick: function(info) {
                showActivityDetails(info.event);
            },
            eventDidMount: function(info) {
                // Thêm tooltip cho event
                $(info.el).tooltip({
                    title: info.event.title,
                    placement: 'top',
                    trigger: 'hover'
                });
            },
            height: 'auto',
            aspectRatio: 1.2,
            dayMaxEvents: true,
            moreLinkClick: 'popover'
        });
        calendar.render();
    }

    async function loadRecentActivitiesForCalendar(successCallback) {
        try {
            // Gọi API để lấy tất cả hoạt động
            const response = await fetch('/HoatDong/GetAllActivitiesForCalendar');
            const activities = await response.json();
            
            // Kiểm tra null và chuyển đổi thành array
            const activitiesArray = activities || [];
            
            const events = activitiesArray.map(activity => {
                // Xử lý an toàn cho các thuộc tính có thể null
                const id = activity.maHoatDong || activity.MaHoatDong || '';
                const title = activity.tieuDe || activity.TieuDe || 'Không có tiêu đề';
                const start = activity.thoiGianBatDau || activity.ThoiGianBatDau || '';
                const end = activity.thoiGianKetThuc || activity.ThoiGianKetThuc || '';
                
                // Xử lý người tạo
                let nguoiTao = 'Chưa cập nhật';
                if (activity.nguoiTao && activity.nguoiTao.userName) {
                    nguoiTao = activity.nguoiTao.userName;
                } else if (activity.NguoiTao && activity.NguoiTao.UserName) {
                    nguoiTao = activity.NguoiTao.UserName;
                } else if (activity.nguoiTaoId) {
                    nguoiTao = activity.nguoiTaoId;
                } else if (activity.NguoiTaoId) {
                    nguoiTao = activity.NguoiTaoId;
                }
                
                // Xử lý mô tả
                const moTa = activity.moTa || activity.MoTa || 'Chưa có mô tả';
                
                // Xử lý màu sắc dựa trên trạng thái
                let backgroundColor = '#3498db'; // Mặc định xanh
                let borderColor = '#2980b9';
                
                if (activity.trangThaiHoatDong) {
                    const trangThai = activity.trangThaiHoatDong.toLowerCase();
                    if (trangThai.includes('đã xác nhận') || trangThai.includes('confirmed')) {
                        backgroundColor = '#27ae60'; // Xanh lá
                        borderColor = '#229954';
                    } else if (trangThai.includes('chờ xác nhận') || trangThai.includes('pending')) {
                        backgroundColor = '#f39c12'; // Cam
                        borderColor = '#e67e22';
                    } else if (trangThai.includes('từ chối') || trangThai.includes('rejected')) {
                        backgroundColor = '#e74c3c'; // Đỏ
                        borderColor = '#c0392b';
                    } else if (trangThai.includes('đã hủy') || trangThai.includes('cancelled')) {
                        backgroundColor = '#95a5a6'; // Xám
                        borderColor = '#7f8c8d';
                    }
                }
                
                return {
                    id: id,
                    title: title,
                    start: start,
                    end: end,
                    backgroundColor: backgroundColor,
                    borderColor: borderColor,
                    textColor: '#ffffff',
                    extendedProps: {
                        nguoiTao: nguoiTao,
                        moTa: moTa,
                        trangThai: activity.trangThaiHoatDong || 'Chưa cập nhật',
                        diaDiem: activity.diaDiem || activity.DiaDiem || 'Chưa cập nhật',
                        danhMuc: activity.danhMuc || activity.DanhMuc || 'Chưa phân loại'
                    }
                };
            });
            
            successCallback(events);
        } catch (error) {
            console.error('Lỗi khi tải hoạt động:', error);
            successCallback([]);
        }
    }

    function showActivityDetails(event) {
        var modal = new bootstrap.Modal(document.getElementById('activityModal'));
        var modalBody = document.getElementById('activityModalBody');
        var viewDetailsBtn = document.getElementById('viewDetailsBtn');

        // Tạo nội dung modal
        var content = `
            <div class="activity-details">
                <div class="activity-detail-item">
                    <i class="fas fa-calendar"></i>
                    <strong>Thời gian:</strong> ${formatDateTime(event.start)} - ${formatDateTime(event.end)}
                </div>
                <div class="activity-detail-item">
                    <i class="fas fa-user"></i>
                    <strong>Người tạo:</strong> ${event.extendedProps.nguoiTao || 'Chưa cập nhật'}
                </div>
                <div class="activity-detail-item">
                    <i class="fas fa-map-marker-alt"></i>
                    <strong>Địa điểm:</strong> ${event.extendedProps.diaDiem || 'Chưa cập nhật'}
                </div>
                <div class="activity-detail-item">
                    <i class="fas fa-tag"></i>
                    <strong>Danh mục:</strong> ${event.extendedProps.danhMuc || 'Chưa phân loại'}
                </div>
                <div class="activity-detail-item">
                    <i class="fas fa-info-circle"></i>
                    <strong>Trạng thái:</strong> ${event.extendedProps.trangThai || 'Chưa cập nhật'}
                </div>
            </div>
            <div class="mt-3">
                <h6>Mô tả:</h6>
                <p>${event.extendedProps.moTa}</p>
            </div>
        `;

        modalBody.innerHTML = content;
        viewDetailsBtn.href = `/HoatDong/Details/${event.id}`;
        modal.show();
    }

    function formatDateTime(date) {
        if (!date) return '';
        return new Date(date).toLocaleString('vi-VN', {
            year: 'numeric',
            month: '2-digit',
            day: '2-digit',
            hour: '2-digit',
            minute: '2-digit'
        });
    }
</script>
