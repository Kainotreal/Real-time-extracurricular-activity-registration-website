@model QuanLyHoatDongNgoaiKhoa.Models.DangKyThamGia
@{
    ViewBag.Title = "Hủy đăng ký";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0">
                        <i class="fas fa-exclamation-triangle"></i> Hủy đăng ký tham gia hoạt động
                    </h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <h5><i class="fas fa-question-circle"></i> Xác nhận hủy đăng ký</h5>
                        <p class="mb-0">
                            Bạn có chắc chắn muốn hủy đăng ký hoạt động <strong>@Model.HoatDong?.TieuDe</strong> không?
                        </p>
                        <p class="mb-0 mt-2">
                            <small class="text-muted">
                                <i class="fas fa-info-circle"></i> Hành động này không thể hoàn tác.
                            </small>
                        </p>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <h6><i class="fas fa-calendar"></i> Thông tin đăng ký:</h6>
                            <ul class="list-unstyled">
                                <li><strong>Hoạt động:</strong> @Model.HoatDong?.TieuDe</li>
                                <li><strong>Ngày đăng ký:</strong> @Model.NgayDangKy.ToString("dd/MM/yyyy HH:mm")</li>
                                <li><strong>Trạng thái:</strong> @Model.TrangThaiDangKy?.TenTrangThaiDangKy</li>
                                @if (!string.IsNullOrEmpty(Model.GhiChu))
                                {
                                    <li><strong>Ghi chú:</strong> @Model.GhiChu</li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <form asp-action="Delete" method="post" id="deleteRegistrationForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.MaDangKy" />
                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("MyRegistrations")" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash"></i> Hủy đăng ký
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>