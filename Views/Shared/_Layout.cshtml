    <!-- UTF-8 Encoding Fix -->
    <script>
        // Đảm bảo encoding UTF-8 cho tiếng Việt
        document.addEventListener('DOMContentLoaded', function() {
            // Đặt charset UTF-8
            if (document.characterSet !== 'UTF-8') {
                console.log('Setting charset to UTF-8');
                document.characterSet = 'UTF-8';
            }
            
            // Đảm bảo meta charset được set đúng
            let metaCharset = document.querySelector('meta[charset]');
            if (!metaCharset) {
                metaCharset = document.createElement('meta');
                metaCharset.setAttribute('charset', 'utf-8');
                document.head.insertBefore(metaCharset, document.head.firstChild);
            } else {
                metaCharset.setAttribute('charset', 'utf-8');
            }
        });
    </script>



    <!-- Dropdown Fix Script -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Đảm bảo Bootstrap dropdown hoạt động
            var dropdownElementList = [].slice.call(document.querySelectorAll('.dropdown-toggle'));
            var dropdownList = dropdownElementList.map(function (dropdownToggleEl) {
                return new bootstrap.Dropdown(dropdownToggleEl);
            });

            // Thêm event listener cho dropdown
            document.querySelectorAll('.dropdown-toggle').forEach(function(element) {
                element.addEventListener('click', function(e) {
                    e.preventDefault();
                    var dropdownMenu = this.nextElementSibling;
                    if (dropdownMenu && dropdownMenu.classList.contains('dropdown-menu')) {
                        dropdownMenu.classList.toggle('show');
                    }
                });
            });

            // Đóng dropdown khi click bên ngoài
            document.addEventListener('click', function(e) {
                if (!e.target.closest('.dropdown')) {
                    document.querySelectorAll('.dropdown-menu.show').forEach(function(menu) {
                        menu.classList.remove('show');
                    });
                }
            });

            // Thêm hover effect cho dropdown trên desktop
            if (window.innerWidth > 768) {
                document.querySelectorAll('.dropdown').forEach(function(dropdown) {
                    dropdown.addEventListener('mouseenter', function() {
                        var menu = this.querySelector('.dropdown-menu');
                        if (menu) {
                            menu.classList.add('show');
                        }
                    });

                    dropdown.addEventListener('mouseleave', function() {
                        var menu = this.querySelector('.dropdown-menu');
                        if (menu) {
                            menu.classList.remove('show');
                        }
                    });
                });
            }
        });
    </script>

    <!-- Font Awesome Check and Load -->
    <script>
        // Kiểm tra Font Awesome đã load chưa
        function checkFontAwesome() {
            const testElement = document.createElement('i');
            testElement.className = 'fas fa-home';
            testElement.style.position = 'absolute';
            testElement.style.left = '-9999px';
            testElement.style.fontSize = '1px';
            document.body.appendChild(testElement);
            
            const computedStyle = window.getComputedStyle(testElement, ':before');
            const content = computedStyle.getPropertyValue('content');
            
            document.body.removeChild(testElement);
            
            // Nếu Font Awesome chưa load, thử load lại
            if (!content || content === 'none' || content === 'normal') {
                console.log('Font Awesome not loaded, attempting to reload...');
                const link = document.createElement('link');
                link.rel = 'stylesheet';
                link.href = 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css';
                document.head.appendChild(link);
            }
        }

        // Kiểm tra khi trang load xong
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(checkFontAwesome, 1000);
        });
    </script>

    <!-- Retro Sound Effects -->
    <script>
        // Retro sound effects for Pixel Art theme
        function playRetroSound(frequency = 440, duration = 100) {
            const audioContext = new (window.AudioContext || window.webkitAudioContext)();
            const oscillator = audioContext.createOscillator();
            const gainNode = audioContext.createGain();
            
            oscillator.connect(gainNode);
            gainNode.connect(audioContext.destination);
            
            oscillator.frequency.setValueAtTime(frequency, audioContext.currentTime);
            oscillator.type = 'square'; // Retro square wave
            
            gainNode.gain.setValueAtTime(0.1, audioContext.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.001, audioContext.currentTime + duration / 1000);
            
            oscillator.start(audioContext.currentTime);
            oscillator.stop(audioContext.currentTime + duration / 1000);
        }

        // Add retro sound to all buttons and links
        document.addEventListener('DOMContentLoaded', function() {
            const buttons = document.querySelectorAll('.btn, .nav-link, .dropdown-item');
            buttons.forEach(button => {
                button.addEventListener('click', function() {
                    // Different sounds for different actions
                    if (this.classList.contains('btn-danger')) {
                        playRetroSound(200, 150); // Low sound for danger
                    } else if (this.classList.contains('btn-success')) {
                        playRetroSound(800, 100); // High sound for success
                    } else {
                        playRetroSound(440, 100); // Default sound
                    }
                    
                    // Add pixel shake effect
                    this.classList.add('pixel-shake');
                    setTimeout(() => {
                        this.classList.remove('pixel-shake');
                    }, 500);
                });
            });

            // Add pixel blink effect to important elements
            const importantElements = document.querySelectorAll('.navbar-brand, .card-header');
            importantElements.forEach(element => {
                // element.classList.add('pixel-blink'); // Removed pixelBlink
            });
        });

        // Retro loading animation
        function showPixelLoading() {
            const loading = document.createElement('div');
            loading.className = 'pixel-loading';
            loading.style.position = 'fixed';
            loading.style.top = '50%';
            loading.style.left = '50%';
            loading.style.transform = 'translate(-50%, -50%)';
            loading.style.zIndex = '9999';
            document.body.appendChild(loading);
            
            setTimeout(() => {
                document.body.removeChild(loading);
            }, 2000);
        }
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
