@{
    ViewData["Title"] = "Báo cáo thống kê";
}

<div class="reports-container">
    <!-- Header Section -->
    <div class="reports-header">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        
        <div class="header-content">
            <div class="header-title">
                <i class="fas fa-chart-bar header-icon"></i>
                <h1>Báo cáo thống kê</h1>
            </div>
            <div class="header-subtitle">
                <p>Thống kê tổng quan hệ thống hoạt động ngoại khóa</p>
            </div>
        </div>
    </div>

    <!-- Thống kê tháng hiện tại -->
    <div class="stats-section">
        <div class="section-header">
            <h2><i class="fas fa-calendar-alt"></i> Thống kê tháng @DateTime.Now.ToString("MM/yyyy")</h2>
        </div>
        <div class="row">
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                    <div class="stat-content">
                        <h3 class="stat-number">@ViewBag.MonthlyStats.ActivitiesThisMonth</h3>
                        <p class="stat-label">Hoạt động mới</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-user-plus"></i>
                    </div>
                    <div class="stat-content">
                        <h3 class="stat-number">@ViewBag.MonthlyStats.RegistrationsThisMonth</h3>
                        <p class="stat-label">Đăng ký mới</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-content">
                        <h3 class="stat-number">@ViewBag.MonthlyStats.TotalUsers</h3>
                        <p class="stat-label">Tổng người dùng</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Thống kê theo danh mục -->
    <div class="stats-section">
        <div class="section-header">
            <h2><i class="fas fa-tags"></i> Thống kê theo danh mục hoạt động</h2>
        </div>
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-chart-pie"></i> Phân bố danh mục</h5>
                    </div>
                    <div class="card-body">
                        @if (ViewBag.CategoryStats != null && ((IEnumerable<dynamic>)ViewBag.CategoryStats).Any())
                        {
                            <div class="category-stats">
                                @foreach (var category in ViewBag.CategoryStats)
                                {
                                    <div class="category-item">
                                        <div class="category-info">
                                            <span class="category-name">@category.Category</span>
                                            <span class="category-count">@category.Count hoạt động</span>
                                        </div>
                                        <div class="category-bar">
                                            @{
                                                var totalCategories = ((IEnumerable<dynamic>)ViewBag.CategoryStats).Sum(c => c.Count);
                                                var percentage = totalCategories > 0 ? (category.Count * 100.0 / totalCategories) : 0;
                                            }
                                            <div class="bar-fill" style="width: @percentage%"></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">Chưa có dữ liệu thống kê</p>
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-chart-line"></i> Trạng thái đăng ký</h5>
                    </div>
                    <div class="card-body">
                        @if (ViewBag.RegistrationStatusStats != null && ((IEnumerable<dynamic>)ViewBag.RegistrationStatusStats).Any())
                        {
                            <div class="status-stats">
                                @foreach (var status in ViewBag.RegistrationStatusStats)
                                {
                                    <div class="status-item">
                                        <div class="status-info">
                                            <span class="status-name">@status.Status</span>
                                            <span class="status-count">@status.Count đăng ký</span>
                                        </div>
                                        <div class="status-bar">
                                            @{
                                                var totalRegistrations = ((IEnumerable<dynamic>)ViewBag.RegistrationStatusStats).Sum(s => s.Count);
                                                var statusPercentage = totalRegistrations > 0 ? (status.Count * 100.0 / totalRegistrations) : 0;
                                            }
                                            <div class="bar-fill" style="width: @statusPercentage%"></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">Chưa có dữ liệu thống kê</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bảng thống kê chi tiết -->
    <div class="stats-section">
        <div class="section-header">
            <h2><i class="fas fa-table"></i> Bảng thống kê chi tiết</h2>
        </div>
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-list"></i> Danh mục hoạt động</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Danh mục</th>
                                        <th>Số lượng</th>
                                        <th>Tỷ lệ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (ViewBag.CategoryStats != null)
                                    {
                                        var totalCategories = ((IEnumerable<dynamic>)ViewBag.CategoryStats).Sum(c => c.Count);
                                        @foreach (var category in ViewBag.CategoryStats)
                                        {
                                            var percentage = totalCategories > 0 ? (category.Count * 100.0 / totalCategories) : 0;
                                            <tr>
                                                <td>@category.Category</td>
                                                <td>@category.Count</td>
                                                <td>@percentage.ToString("F1")%</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-list-check"></i> Trạng thái đăng ký</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Trạng thái</th>
                                        <th>Số lượng</th>
                                        <th>Tỷ lệ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (ViewBag.RegistrationStatusStats != null)
                                    {
                                        var totalRegistrations = ((IEnumerable<dynamic>)ViewBag.RegistrationStatusStats).Sum(s => s.Count);
                                        @foreach (var status in ViewBag.RegistrationStatusStats)
                                        {
                                            var percentage = totalRegistrations > 0 ? (status.Count * 100.0 / totalRegistrations) : 0;
                                            <tr>
                                                <td>@status.Status</td>
                                                <td>@status.Count</td>
                                                <td>@percentage.ToString("F1")%</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .reports-container {
        padding: 20px;
    }

    .reports-header {
        background: linear-gradient(135deg, var(--pixel-blue-dark), var(--pixel-blue-navy));
        color: var(--pixel-white);
        padding: 30px;
        border-radius: 12px;
        margin-bottom: 30px;
        border: var(--pixel-border);
        box-shadow: var(--pixel-shadow);
    }

    .header-content {
        text-align: center;
    }

    .header-title {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 10px;
    }

    .header-icon {
        font-size: 2rem;
        margin-right: 15px;
    }

    .header-title h1 {
        margin: 0;
        font-size: 2.5rem;
        font-weight: bold;
    }

    .header-subtitle p {
        margin: 0;
        font-size: 1.2rem;
        opacity: 0.9;
    }

    .stats-section {
        margin-bottom: 40px;
    }

    .section-header {
        margin-bottom: 20px;
    }

    .section-header h2 {
        color: var(--pixel-dark);
        font-size: 1.8rem;
        font-weight: bold;
        display: flex;
        align-items: center;
    }

    .section-header h2 i {
        margin-right: 10px;
        color: var(--pixel-blue-dark);
    }

    .stat-card {
        background: var(--pixel-white);
        border: var(--pixel-border);
        box-shadow: var(--pixel-shadow);
        border-radius: 12px;
        padding: 25px;
        text-align: center;
        transition: all 0.3s ease;
        margin-bottom: 20px;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 6px 6px 0px var(--pixel-black);
    }

    .stat-icon {
        font-size: 3rem;
        color: var(--pixel-blue-dark);
        margin-bottom: 15px;
    }

    .stat-number {
        font-size: 2.5rem;
        font-weight: bold;
        color: var(--pixel-dark);
        margin: 0;
    }

    .stat-label {
        font-size: 1.1rem;
        color: var(--pixel-gray);
        margin: 5px 0 0 0;
    }

    .category-stats, .status-stats {
        max-height: 300px;
        overflow-y: auto;
    }

    .category-item, .status-item {
        margin-bottom: 15px;
        padding: 10px;
        border: 1px solid var(--pixel-black);
        border-radius: 8px;
        background: var(--pixel-white);
    }

    .category-info, .status-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    .category-name, .status-name {
        font-weight: bold;
        color: var(--pixel-dark);
    }

    .category-count, .status-count {
        color: var(--pixel-gray);
        font-size: 0.9rem;
    }

    .category-bar, .status-bar {
        height: 8px;
        background: var(--pixel-gray);
        border-radius: 4px;
        overflow: hidden;
        border: 1px solid var(--pixel-black);
    }

    .bar-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--pixel-blue-dark), var(--pixel-blue-navy));
        transition: width 0.3s ease;
    }

    .table {
        font-size: 0.9rem;
    }

    .table th {
        background: var(--pixel-blue-dark);
        color: var(--pixel-white);
        border: 1px solid var(--pixel-black);
    }

    .table td {
        border: 1px solid var(--pixel-black);
        vertical-align: middle;
    }

    .table tbody tr:hover {
        background: var(--pixel-blue-light);
    }

    @@media (max-width: 768px) {
        .reports-header {
            padding: 20px;
        }

        .header-title h1 {
            font-size: 2rem;
        }

        .stat-card {
            padding: 20px;
        }

        .stat-number {
            font-size: 2rem;
        }

        .category-info, .status-info {
            flex-direction: column;
            align-items: flex-start;
        }

        .category-count, .status-count {
            margin-top: 5px;
        }
    }
</style> 