@model IEnumerable<object>

@{
    ViewData["Title"] = "Lịch hoạt động";
}

<div class="calendar-container">
    <div class="card">
        <div class="card-header">
            <h2><i class="fas fa-calendar-alt"></i> Lịch hoạt động</h2>
            <div class="calendar-controls">
                <button class="btn btn-outline-primary btn-sm" onclick="prevMonth()">
                    <i class="fas fa-chevron-left"></i> Tháng trước
                </button>
                <button class="btn btn-outline-primary btn-sm" onclick="nextMonth()">
                    Tháng sau <i class="fas fa-chevron-right"></i>
                </button>
                <button class="btn btn-outline-success btn-sm" onclick="today()">
                    <i class="fas fa-calendar-day"></i> Hôm nay
                </button>
            </div>
        </div>
        <div class="card-body">
            <div id="calendar"></div>
        </div>
    </div>
</div>

<!-- Modal chi tiết hoạt động -->
<div class="modal fade" id="activityModal" tabindex="-1" aria-labelledby="activityModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="activityModalLabel">Chi tiết hoạt động</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="activityModalBody">
                <!-- Nội dung sẽ được load động -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <a href="#" class="btn btn-primary" id="viewDetailsBtn">Xem chi tiết</a>
            </div>
        </div>
    </div>
</div>

<!-- Modal kiểm tra xung đột -->
<div class="modal fade" id="conflictModal" tabindex="-1" aria-labelledby="conflictModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="conflictModalLabel">
                    <i class="fas fa-exclamation-triangle text-warning"></i> Phát hiện xung đột lịch
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="conflictModalBody">
                <!-- Nội dung xung đột sẽ được load động -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-warning" id="suggestTimeBtn">
                    <i class="fas fa-clock"></i> Đề xuất thời gian khác
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .calendar-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    .calendar-controls {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    #calendar {
        min-height: 600px;
    }

    .fc-event {
        cursor: pointer;
        border-radius: 4px;
        font-size: 0.9rem;
        padding: 2px 4px;
    }

    .fc-event:hover {
        opacity: 0.8;
        transform: scale(1.02);
        transition: all 0.2s ease;
    }

    .activity-details {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin-bottom: 15px;
    }

    .activity-detail-item {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .activity-detail-item i {
        width: 20px;
        color: #6c757d;
    }

    .conflict-list {
        max-height: 300px;
        overflow-y: auto;
    }

    .conflict-item {
        padding: 10px;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        margin-bottom: 10px;
        background-color: #f8f9fa;
    }

    .conflict-item h6 {
        margin-bottom: 5px;
        color: #dc3545;
    }

    .suggestion-list {
        max-height: 200px;
        overflow-y: auto;
    }

    .suggestion-item {
        padding: 8px;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        margin-bottom: 5px;
        background-color: #e8f5e8;
        cursor: pointer;
    }

    .suggestion-item:hover {
        background-color: #d4edda;
    }

    .score-badge {
        float: right;
        background-color: #28a745;
        color: white;
        padding: 2px 6px;
        border-radius: 10px;
        font-size: 0.8rem;
    }

    @@media (max-width: 768px) {
        .calendar-container {
            padding: 10px;
        }

        .calendar-controls {
            flex-direction: column;
            align-items: stretch;
        }

        .activity-details {
            grid-template-columns: 1fr;
        }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/locales/vi.global.min.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var calendarEl = document.getElementById('calendar');
        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            locale: 'vi',
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek,timeGridDay'
            },
            buttonText: {
                today: 'Hôm nay',
                month: 'Tháng',
                week: 'Tuần',
                day: 'Ngày'
            },
            events: @Html.Raw(Json.Serialize(Model)),
            eventClick: function(info) {
                showActivityDetails(info.event);
            },
            eventDidMount: function(info) {
                // Thêm tooltip cho event
                $(info.el).tooltip({
                    title: info.event.title,
                    placement: 'top',
                    trigger: 'hover'
                });
            },
            height: 'auto',
            aspectRatio: 1.35,
            dayMaxEvents: true,
            moreLinkClick: 'popover'
        });
        calendar.render();

        // Lưu calendar instance để sử dụng trong các function khác
        window.calendar = calendar;
    });

    function showActivityDetails(event) {
        var modal = new bootstrap.Modal(document.getElementById('activityModal'));
        var modalBody = document.getElementById('activityModalBody');
        var viewDetailsBtn = document.getElementById('viewDetailsBtn');

        // Tạo nội dung modal
        var content = `
            <div class="activity-details">
                <div class="activity-detail-item">
                    <i class="fas fa-calendar"></i>
                    <strong>Thời gian:</strong> ${formatDateTime(event.start)} - ${formatDateTime(event.end)}
                </div>
                <div class="activity-detail-item">
                    <i class="fas fa-map-marker-alt"></i>
                    <strong>Địa điểm:</strong> ${event.extendedProps.location || 'Chưa cập nhật'}
                </div>
                <div class="activity-detail-item">
                    <i class="fas fa-tag"></i>
                    <strong>Danh mục:</strong> ${event.extendedProps.category || 'Chưa cập nhật'}
                </div>
                <div class="activity-detail-item">
                    <i class="fas fa-info-circle"></i>
                    <strong>Trạng thái:</strong> ${event.extendedProps.status || 'Chưa cập nhật'}
                </div>
            </div>
            <div class="mt-3">
                <h6>Mô tả:</h6>
                <p>${event.extendedProps.description || 'Chưa có mô tả'}</p>
            </div>
        `;

        modalBody.innerHTML = content;
        viewDetailsBtn.href = `/HoatDong/Details/${event.id}`;
        modal.show();
    }

    function formatDateTime(date) {
        if (!date) return '';
        return new Date(date).toLocaleString('vi-VN', {
            year: 'numeric',
            month: '2-digit',
            day: '2-digit',
            hour: '2-digit',
            minute: '2-digit'
        });
    }

    function prevMonth() {
        window.calendar.prev();
    }

    function nextMonth() {
        window.calendar.next();
    }

    function today() {
        window.calendar.today();
    }

    // Function kiểm tra xung đột
    async function checkConflict(maHoatDong) {
        try {
            const response = await fetch(`/ScheduleOptimization/CheckConflict?maHoatDong=${maHoatDong}`);
            const result = await response.json();
            
            if (result.hasConflict) {
                showConflictModal(result);
            }
            
            return result;
        } catch (error) {
            console.error('Lỗi khi kiểm tra xung đột:', error);
        }
    }

    function showConflictModal(conflictData) {
        var modal = new bootstrap.Modal(document.getElementById('conflictModal'));
        var modalBody = document.getElementById('conflictModalBody');

        var content = `
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle"></i>
                <strong>Phát hiện xung đột lịch!</strong>
            </div>
            <div class="conflict-list">
                <h6>Hoạt động xung đột:</h6>
                ${conflictData.conflictingActivities.map(activity => `
                    <div class="conflict-item">
                        <h6>${activity.tieuDe}</h6>
                        <p><i class="fas fa-clock"></i> ${formatDateTime(activity.thoiGianBatDau)} - ${formatDateTime(activity.thoiGianKetThuc)}</p>
                        <p><i class="fas fa-map-marker-alt"></i> ${activity.diaDiem}</p>
                        <p><i class="fas fa-info-circle"></i> ${activity.trangThai}</p>
                    </div>
                `).join('')}
            </div>
        `;

        modalBody.innerHTML = content;
        modal.show();
    }

    // Function đề xuất thời gian
    async function suggestTimeSlots(maHoatDong) {
        try {
            const response = await fetch(`/ScheduleOptimization/SuggestTimeSlots?maHoatDong=${maHoatDong}`);
            const suggestions = await response.json();
            
            showSuggestionsModal(suggestions);
        } catch (error) {
            console.error('Lỗi khi lấy đề xuất thời gian:', error);
        }
    }

    function showSuggestionsModal(suggestions) {
        var modal = new bootstrap.Modal(document.getElementById('conflictModal'));
        var modalBody = document.getElementById('conflictModalBody');

        var content = `
            <div class="alert alert-info">
                <i class="fas fa-lightbulb"></i>
                <strong>Đề xuất thời gian tối ưu:</strong>
            </div>
            <div class="suggestion-list">
                ${suggestions.map(suggestion => `
                    <div class="suggestion-item" onclick="selectTimeSlot('${suggestion.startTime}', '${suggestion.endTime}', ${suggestion.diaDiemId})">
                        <span class="score-badge">${Math.round(suggestion.score)} điểm</span>
                        <strong>${suggestion.diaDiemName}</strong><br>
                        <i class="fas fa-clock"></i> ${suggestion.startTime} - ${suggestion.endTime}
                    </div>
                `).join('')}
            </div>
        `;

        modalBody.innerHTML = content;
        modal.show();
    }

    function selectTimeSlot(startTime, endTime, diaDiemId) {
        // Có thể implement để cập nhật form tạo hoạt động
        console.log('Đã chọn thời gian:', startTime, endTime, diaDiemId);
        bootstrap.Modal.getInstance(document.getElementById('conflictModal')).hide();
    }

    // Gắn event cho button đề xuất thời gian
    document.getElementById('suggestTimeBtn').addEventListener('click', function() {
        // Lấy maHoatDong từ context hiện tại
        const currentActivityId = getCurrentActivityId();
        if (currentActivityId) {
            suggestTimeSlots(currentActivityId);
        }
    });

    function getCurrentActivityId() {
        // Implement để lấy ID hoạt động hiện tại
        // Có thể lưu trong data attribute hoặc global variable
        return null;
    }
</script> 