@model dynamic

@{
    ViewData["Title"] = "Thống kê tối ưu hóa lịch";
}

<div class="statistics-container">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h2><i class="fas fa-chart-line"></i> Thống kê tối ưu hóa lịch</h2>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="stat-card">
                                <div class="stat-icon">
                                    <i class="fas fa-calendar-check text-success"></i>
                                </div>
                                <div class="stat-content">
                                    <h3 id="totalActivities">0</h3>
                                    <p>Tổng hoạt động</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stat-card">
                                <div class="stat-icon">
                                    <i class="fas fa-exclamation-triangle text-warning"></i>
                                </div>
                                <div class="stat-content">
                                    <h3 id="conflictCount">0</h3>
                                    <p>Xung đột đã phát hiện</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stat-card">
                                <div class="stat-icon">
                                    <i class="fas fa-users text-info"></i>
                                </div>
                                <div class="stat-content">
                                    <h3 id="totalRegistrations">0</h3>
                                    <p>Tổng đăng ký</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stat-card">
                                <div class="stat-icon">
                                    <i class="fas fa-clock text-primary"></i>
                                </div>
                                <div class="stat-content">
                                    <h3 id="optimizationRate">0%</h3>
                                    <p>Tỷ lệ tối ưu</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-4">
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header">
                                    <h5><i class="fas fa-chart-pie"></i> Phân bố xung đột</h5>
                                </div>
                                <div class="card-body">
                                    <canvas id="conflictChart"></canvas>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header">
                                    <h5><i class="fas fa-chart-bar"></i> Hoạt động theo thời gian</h5>
                                </div>
                                <div class="card-body">
                                    <canvas id="timeChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-4">
                        <div class="col-md-12">
                            <div class="card">
                                <div class="card-header">
                                    <h5><i class="fas fa-calendar-alt"></i> Hoạt động gần đây</h5>
                                </div>
                                <div class="card-body">
                                    <div id="recentActivitiesCalendar"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal chi tiết hoạt động -->
<div class="modal fade" id="activityModal" tabindex="-1" aria-labelledby="activityModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="activityModalLabel">Chi tiết hoạt động</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="activityModalBody">
                <!-- Nội dung sẽ được load động -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <a href="#" class="btn btn-primary" id="viewDetailsBtn">Xem chi tiết</a>
            </div>
        </div>
    </div>
</div>

<style>
    .statistics-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    .stat-card {
        display: flex;
        align-items: center;
        padding: 20px;
        background: #ffffff;
        border-radius: 12px;
        border: 3px solid #000;
        box-shadow: 4px 4px 0px rgba(0, 0, 0, 0.8);
        transition: all 0.3s ease;
        margin-bottom: 20px;
    }

    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 6px 6px 0px rgba(0, 0, 0, 0.8);
    }

    .stat-icon {
        font-size: 2.5rem;
        margin-right: 20px;
        flex-shrink: 0;
    }

    .stat-content h3 {
        margin: 0;
        font-size: 2rem;
        font-weight: bold;
        color: #2c3e50;
    }

    .stat-content p {
        margin: 5px 0 0 0;
        color: #7f8c8d;
        font-size: 0.9rem;
    }

    .card {
        border: 3px solid #000;
        box-shadow: 4px 4px 0px rgba(0, 0, 0, 0.8);
        border-radius: 12px;
        margin-bottom: 20px;
    }

    .card-header {
        background: #f8f9fa;
        border-bottom: 2px solid #000;
        padding: 15px 20px;
    }

    .card-header h2, .card-header h5 {
        margin: 0;
        color: #2c3e50;
    }

    #recentActivitiesCalendar {
        min-height: 400px;
    }

    .fc-event {
        cursor: pointer;
        border-radius: 4px;
        font-size: 0.9rem;
        padding: 2px 4px;
    }

    .fc-event:hover {
        opacity: 0.8;
        transform: scale(1.02);
        transition: all 0.2s ease;
    }

    .activity-details {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin-bottom: 15px;
    }

    .activity-detail-item {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .activity-detail-item i {
        width: 20px;
        color: #6c757d;
    }

    .conflict-badge {
        background: #dc3545;
        color: white;
        padding: 4px 8px;
        border-radius: 12px;
        font-size: 0.8rem;
    }

    .no-conflict-badge {
        background: #28a745;
        color: white;
        padding: 4px 8px;
        border-radius: 12px;
        font-size: 0.8rem;
    }

    @@media (max-width: 768px) {
        .statistics-container {
            padding: 10px;
        }

        .stat-card {
            padding: 15px;
        }

        .stat-icon {
            font-size: 2rem;
            margin-right: 15px;
        }

        .stat-content h3 {
            font-size: 1.5rem;
        }

        .activity-details {
            grid-template-columns: 1fr;
        }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/locales/vi.global.min.js"></script>
<script src="~/js/schedule-optimization.js"></script>

<script>
    let recentActivitiesCalendar;

    document.addEventListener('DOMContentLoaded', function() {
        loadStatistics();
        initializeRecentActivitiesCalendar();
        initializeCharts();
    });

    async function loadStatistics() {
        try {
            const response = await fetch('/ScheduleOptimization/GetStatistics');
            const data = await response.json();
            
            document.getElementById('totalActivities').textContent = data.totalActivities || 0;
            document.getElementById('conflictCount').textContent = data.conflictCount || 0;
            document.getElementById('totalRegistrations').textContent = data.totalRegistrations || 0;
            
            const optimizationRate = data.totalActivities > 0 ? 
                Math.round((data.totalActivities - data.conflictCount) / data.totalActivities * 100) : 0;
            document.getElementById('optimizationRate').textContent = optimizationRate + '%';
        } catch (error) {
            console.error('Lỗi khi tải thống kê:', error);
        }
    }

    function initializeRecentActivitiesCalendar() {
        const calendarEl = document.getElementById('recentActivitiesCalendar');
        recentActivitiesCalendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            locale: 'vi',
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek'
            },
            buttonText: {
                today: 'Hôm nay',
                month: 'Tháng',
                week: 'Tuần'
            },
            events: function(fetchInfo, successCallback, failureCallback) {
                loadRecentActivitiesForCalendar(successCallback);
            },
            eventClick: function(info) {
                showActivityDetails(info.event);
            },
            eventDidMount: function(info) {
                // Thêm tooltip cho event
                $(info.el).tooltip({
                    title: info.event.title,
                    placement: 'top',
                    trigger: 'hover'
                });
            },
            height: 'auto',
            aspectRatio: 1.35,
            dayMaxEvents: true,
            moreLinkClick: 'popover'
        });
        recentActivitiesCalendar.render();
    }

    async function loadRecentActivitiesForCalendar(successCallback) {
        try {
            const response = await fetch('/ScheduleOptimization/GetRecentActivities');
            const activities = await response.json();
            
            const events = activities.map(activity => ({
                id: activity.maHoatDong,
                title: activity.tieuDe,
                start: activity.thoiGianBatDau,
                end: activity.thoiGianKetThuc,
                backgroundColor: activity.hasConflict ? '#dc3545' : '#28a745',
                borderColor: activity.hasConflict ? '#dc3545' : '#28a745',
                textColor: '#ffffff',
                extendedProps: {
                    danhMuc: activity.danhMuc,
                    diaDiem: activity.diaDiem,
                    trangThai: activity.trangThai,
                    hasConflict: activity.hasConflict,
                    description: activity.moTa || 'Chưa có mô tả'
                }
            }));
            
            successCallback(events);
        } catch (error) {
            console.error('Lỗi khi tải hoạt động gần đây:', error);
            successCallback([]);
        }
    }

    function showActivityDetails(event) {
        var modal = new bootstrap.Modal(document.getElementById('activityModal'));
        var modalBody = document.getElementById('activityModalBody');
        var viewDetailsBtn = document.getElementById('viewDetailsBtn');

        // Tạo nội dung modal
        var content = `
            <div class="activity-details">
                <div class="activity-detail-item">
                    <i class="fas fa-calendar"></i>
                    <strong>Thời gian:</strong> ${formatDateTime(event.start)} - ${formatDateTime(event.end)}
                </div>
                <div class="activity-detail-item">
                    <i class="fas fa-map-marker-alt"></i>
                    <strong>Địa điểm:</strong> ${event.extendedProps.diaDiem || 'Chưa cập nhật'}
                </div>
                <div class="activity-detail-item">
                    <i class="fas fa-tag"></i>
                    <strong>Danh mục:</strong> ${event.extendedProps.danhMuc || 'Chưa cập nhật'}
                </div>
                <div class="activity-detail-item">
                    <i class="fas fa-info-circle"></i>
                    <strong>Trạng thái:</strong> ${event.extendedProps.trangThai || 'Chưa cập nhật'}
                </div>
            </div>
            <div class="mt-3">
                <h6>Mô tả:</h6>
                <p>${event.extendedProps.description}</p>
            </div>
            <div class="mt-3">
                <span class="${event.extendedProps.hasConflict ? 'conflict-badge' : 'no-conflict-badge'}">
                    ${event.extendedProps.hasConflict ? 'Có xung đột' : 'Không xung đột'}
                </span>
            </div>
        `;

        modalBody.innerHTML = content;
        viewDetailsBtn.href = `/HoatDong/Details/${event.id}`;
        modal.show();
    }

    function initializeCharts() {
        // Chart cho phân bố xung đột
        const conflictCtx = document.getElementById('conflictChart').getContext('2d');
        new Chart(conflictCtx, {
            type: 'doughnut',
            data: {
                labels: ['Không xung đột', 'Xung đột thời gian', 'Xung đột địa điểm', 'Xung đột người dùng'],
                datasets: [{
                    data: [70, 15, 10, 5],
                    backgroundColor: [
                        '#28a745',
                        '#ffc107',
                        '#dc3545',
                        '#6c757d'
                    ]
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });

        // Chart cho hoạt động theo thời gian
        const timeCtx = document.getElementById('timeChart').getContext('2d');
        new Chart(timeCtx, {
            type: 'bar',
            data: {
                labels: ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'],
                datasets: [{
                    label: 'Số hoạt động',
                    data: [12, 19, 15, 25, 22, 30, 18],
                    backgroundColor: '#007bff'
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });
    }

    function formatDateTime(date) {
        if (!date) return '';
        return new Date(date).toLocaleString('vi-VN', {
            year: 'numeric',
            month: '2-digit',
            day: '2-digit',
            hour: '2-digit',
            minute: '2-digit'
        });
    }

    function getStatusBadgeClass(status) {
        switch (status) {
            case 'Đã xác nhận': return 'success';
            case 'Chờ xác nhận': return 'warning';
            case 'Từ chối': return 'danger';
            case 'Đã hủy': return 'secondary';
            default: return 'info';
        }
    }
</script> 